# ─── Backend ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000

# PostgreSQL
POSTGRES_USER=argraph
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_research_graph
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://argraph:change-me@postgres:5432/ai_research_graph

# Redis
REDIS_URL=redis://redis:6379/0

# Vector DB (qdrant | pinecone | weaviate)
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=research_chunks
# Pinecone (if VECTOR_BACKEND=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=research-graph
# Weaviate (if VECTOR_BACKEND=weaviate)
WEAVIATE_URL=

# Embeddings / LLM
# Defaults require NO API key: local hashing embeddings + extractive (no-LLM) answers.
EMBEDDING_PROVIDER=local          # local | openai
EMBEDDING_DIM=384
LLM_PROVIDER=none                 # none | openai
# Only needed when a provider above is set to openai:
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
